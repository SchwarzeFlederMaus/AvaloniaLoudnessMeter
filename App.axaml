<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LoudnessMeter.App"
             RequestedThemeVariant="Light">
             <!--RequestedThemeVariant="Default">-->
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/LargeLabelControl.axaml" />
    </Application.Styles>

    <Application.Resources>
        <SolidColorBrush x:Key="MediumGrayBrush">#e5e5e5</SolidColorBrush>

        <SolidColorBrush x:Key="LightBlueBrush">#605875</SolidColorBrush>
        <SolidColorBrush x:Key="MidBlueBrush">#373c44</SolidColorBrush>
        <SolidColorBrush x:Key="DarkBlueBrush">#1a1c20</SolidColorBrush>
        <SolidColorBrush x:Key="BrigthBlueBrush">#7f98c7</SolidColorBrush>
        <SolidColorBrush x:Key="BrigthHoverBlueBrush">#98acd0</SolidColorBrush>

        <SolidColorBrush x:Key="FadedRedBrush">#bc7c7a</SolidColorBrush>
    </Application.Resources>
</Application>