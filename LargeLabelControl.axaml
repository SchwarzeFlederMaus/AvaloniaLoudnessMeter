<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:LoudnessMeter">

    <Design.PreviewWith>
        <Border Background="{DynamicResource DarkBlueBrush}">
            <StackPanel Margin="10">
                <controls:LargeLabelControl Margin="5" />
                <controls:LargeLabelControl Margin="5" Classes="button" />
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <Style Selector="controls|LargeLabelControl">
        <!-- Set Defaults -->
        <Setter Property="Background" Value="{DynamicResource MidBlueBrush}"></Setter>
        <Setter Property="Foreground" Value="White"></Setter>
        
        <Setter Property="Template">
            <ControlTemplate>
                <Border Padding="15,7" Background="{TemplateBinding Background}">
                    <StackPanel>
                        <Label Content="{TemplateBinding LargeText}" 
                               HorizontalAlignment="Center" 
                               Padding="0" 
                               Foreground="{TemplateBinding Foreground}" 
                               FontSize="21"/>
                        <Label Content="{TemplateBinding SmallText}" 
                               HorizontalAlignment="Center" 
                               Padding="0" 
                               Foreground="{TemplateBinding Foreground}" 
                               FontSize="11"/>
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    
    <Style Selector="controls|LargeLabelControl.button">
        
        <Setter Property="Template">
            <ControlTemplate>
                <StackPanel>
                    <Label Content="{TemplateBinding LargeText}" 
                           CornerRadius="20" 
                           HorizontalAlignment="Center" 
                           Padding="15,3" 
                           Background="{TemplateBinding Background}"
                           Foreground="{TemplateBinding Foreground}" 
                           FontSize="21"/>
                    <Label Content="{TemplateBinding SmallText}" 
                           HorizontalAlignment="Center" 
                           Margin="0,5" 
                           Padding="0" 
                           Foreground="{TemplateBinding Foreground}" 
                           FontSize="11"/>
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
