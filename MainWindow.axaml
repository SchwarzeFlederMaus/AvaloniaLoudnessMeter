<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
        x:Class="LoudnessMeter.MainWindow"
        Title="TestApp">
    <Grid RowDefinitions="Auto, *, Auto">
        <!--Title bar-->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, *, Auto, Auto" Background="Orange" Height="40">
            <Rectangle Grid.Column="0" Fill="Red" Width="40"/>
            <Rectangle Grid.Column="1" Fill="Blue" Width="40"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label FontWeight="Black">AVALONIA</Label>
                <Label>LOUDNESS METER</Label>
            </StackPanel>
            <Rectangle Grid.Column="3" Fill="Green" Width="40"/>
            <Rectangle Grid.Column="4" Fill="Yellow" Width="40"/>
        </Grid>

        <!--Main area-->
        <Grid Grid.Row="1" ColumnDefinitions="Auto, Auto, *">
            <!--Volume bar-->
            <Rectangle Grid.Column="0" Fill="Purple" Width="110"/>
            <!--Details panel-->
            <Rectangle Grid.Column="1" Fill="LightGray" Width="140"/>
            <!--Graph-->
            <Rectangle Grid.Column="2" Fill="DarkBlue"/>
        </Grid>

        <!--Bottom bar-->
        <Grid Grid.Row="2" ColumnDefinitions="Auto, Auto, *, Auto, Auto, Auto, Auto, Auto" Margin="8">
            <Button Grid.Column="0" Margin="0,0,8,0">Stereo</Button>
            <Button Grid.Column="1">YouTube</Button>

            <Button Grid.Column="3" Margin="0,0,8,0">10 SEC</Button>
            <Button Grid.Column="4" Margin="0,0,8,0">CONTINOUS</Button>
            <Rectangle Grid.Column="5" Fill="Orange" Margin="0,0,8,0" Width="30"/>
            <Rectangle Grid.Column="6" Fill="Red" Width="30"/>
        </Grid>
    </Grid>
</Window>
